      "cell_type": "code",
      "source": [
        "from google.colab import drive\n",
        "drive.mount('/content/drive')"
      ],
      "metadata": {
        "id": "hn_ruPYnDvpR"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import os, subprocess, textwrap, sys\n",
        "\n",
        "def run(cmd):\n",
        "    print(\" \".join(cmd))\n",
        "    subprocess.run(cmd, check=True)\n",
        "\n",
        "# system deps\n",
        "run([\"apt-get\",\"-qq\",\"update\"])\n",
        "run([\"apt-get\",\"-qq\",\"install\",\"-y\",\"ffmpeg\",\"cmake\",\"build-essential\",\"git\"])\n",
        "\n",
        "# clone + build\n",
        "os.chdir(\"/content\")\n",
        "if not os.path.exists(\"whisper.cpp\"):\n",
        "    run([\"git\",\"clone\",\"https://github.com/ggml-org/whisper.cpp\"])\n",
        "os.chdir(\"/content/whisper.cpp\")\n",
        "\n",
        "run([\"cmake\",\"-B\",\"build\"])\n",
        "run([\"cmake\",\"--build\",\"build\",\"-j\"])"
      ],
      "metadata": {
        "id": "d3bO0l8SKC21"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        " **download a multilingual model (could be base, small, medium, large)\n",
        "!Attention: large model may crash Google Colab**"
