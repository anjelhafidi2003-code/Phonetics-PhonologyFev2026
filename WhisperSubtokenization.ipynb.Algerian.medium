    },
    {
      "cell_type": "markdown",
      "source": [
        "**install + build whisper.cpp (https://github.com/ggml-org/whisper.cpp**)"
      ],
      "metadata": {
        "id": "Xouh2GZtOwhl"
      }
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "9f35d1a3"
      },
      "source": [
        "### Prepare 'Algerian.wav' for transcription\n",
        "\n",
        "Please ensure your 'Algerian.wav' file is uploaded to `/content/Algerian.wav` before running the next cell. You can upload it by clicking the folder icon on the left sidebar, then the upload icon, and selecting your file."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "68218b64",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "97dbb2f2-3ec8-409d-9034-a68b37986f0e"
      },
      "source": [
        "import subprocess\n",
        "\n",
        "WAV_IN  = \"/content/Algerian.wav\" # Updated for the new audio file\n",
        "WAV_16K = \"/content/audio_16k_Algerian.wav\" # New output path for 16k mono WAV\n",
        "\n",
        "subprocess.run([\n",
        "    \"ffmpeg\",\"-y\",\"-i\",WAV_IN,\n",
        "    \"-ar\",\"16000\",\"-ac\",\"1\",\"-c:a\",\"pcm_s16le\",\n",
        "    WAV_16K\n",
        "], check=True)"
      ],
      "execution_count": 13,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "CompletedProcess(args=['ffmpeg', '-y', '-i', '/content/Algerian.wav', '-ar', '16000', '-ac', '1', '-c:a', 'pcm_s16le', '/content/audio_16k_Algerian.wav'], returncode=0)"
            ]
          },
          "metadata": {},
          "execution_count": 13
        }
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "9254cad4"
      },
      "source": [
        "### Transcribe 'Algerian.wav' + get tokens\n",
        "\n",
        "This cell will perform the transcription and save the results as `out_Algerian.json` and `tokens_Algerian.csv` in the `/content/` directory."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "d5669c53"
      },
      "source": [
        "import os, subprocess, json\n",
        "import re\n",
        "\n",
        "os.chdir(\"/content/whisper.cpp\")\n",
        "\n",
        "MODEL = \"models/ggml-medium.bin\"     # Changed to medium model\n",
        "AUDIO = \"/content/audio_16k_Algerian.wav\" # Input for whisper-cli is the 16k mono WAV\n",
        "OUT_JSON_PREFIX = \"/content/transcription_Algerian\" # New prefix for JSON output\n",
        "TOKEN_CSV_FILENAME = \"/content/Tokens.4.csv\" # Specific filename for tokens CSV\n",
        "\n",
        "subprocess.run(\n",
        "    [\n",
        "        \"./build/bin/whisper-cli\",\n",
        "        \"-m\", MODEL,\n",
        "        \"-f\", AUDIO,\n",
        "        \"-l\", \"auto\",        # or \"fr\", \"ar\", ...\n",
        "        \"-ojf\",\n",
        "        \"-dtw\", \"base\",\n",
        "        \"-of\", OUT_JSON_PREFIX # Use the new JSON prefix here\n",
        "    ], check=True)\n",
        "\n",
        "# Attempt to read the file with utf-8, replacing problematic characters\n",
        "with open(f\"{OUT_JSON_PREFIX}.json\", \"r\", encoding=\"utf-8\", errors=\"replace\") as f:\n",
        "    json_str = f.read()\n",
        "\n",
        "# Remove invalid control characters that might break JSON parsing.\n",
        "# This regex matches any control character (0x00-0x1F) except tab (0x09), newline (0x0A), and carriage return (0x0D).\n",
        "# These specific control characters are generally allowed in JSON strings if escaped.\n",
        "# Other control characters are not allowed unescaped.\n",
        "control_chars = re.compile(r'[\\x00-\\x08\\x0B\\x0C\\x0E-\\x1F]')\n",
        "cleaned_json_str = control_chars.sub(lambda x: f'\\\\u{ord(x.group()):04x}', json_str)\n",
        "\n",
        "# Now try parsing the cleaned string\n",
        "j = json.loads(cleaned_json_str)\n",
        "\n",
        "rows = []\n",
        "for seg in j.get(\"transcription\", []):\n",
        "    for tok in seg.get(\"tokens\", []):\n",
        "        offs = tok.get(\"offsets\", {})  # ms, when available\n",
        "        rows.append({\n",
        "            \"token\": tok.get(\"text\"),\n",
        "            \"start_ms\": offs.get(\"from\"),\n",
        "            \"end_ms\": offs.get(\"to\"),\n",
        "            \"p\": tok.get(\"p\"),\n",
        "            \"id\": tok.get(\"id\"),\n",
        "        })\n",
        "\n",
        "__import__(\"pandas\").DataFrame(rows).to_csv(TOKEN_CSV_FILENAME, index=False) # Use the specific CSV filename\n",
        "\n",
        "# print first tokens\n",
        "print(\"\\nFirst 40 tokens:\")\n",
        "for r in rows[:40]:\n",
        "    print(r)\n",
        "\n",
        "# print ALL tokens\n",
        "print(f\"\\nTotal tokens: {len(rows)}\\n\")\n",
        "print(\"All tokens:\")\n",
        "for i, r in enumerate(rows, 1):\n",
        "    print(f\"{i}. {r}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "e42082d3"
      },
      "source": [
        "You can now manually download the `transcription_Algerian.json` and `Tokens.4.csv` files. Click on the folder icon on the left sidebar, navigate to `/content/`, right-click on the desired file, and select 'Download'."
      ]
    },
