        "\n",
        "def normalize_arabic(text):\n",
        "\n",
        "    # 1. Remove diacritics (the small marks above/below letters like َ ُ ِ)\n",
        "    text = re.sub(r'[\\u064B-\\u065F\\u0670]', '', text)\n",
        "\n",
        "    # 2. Normalize alef variants (إ أ آ ٱ all become ا)\n",
        "    text = re.sub(r'[إأآٱ]', 'ا', text)\n",
        "\n",
        "    # 3. Normalize waw with hamza (ؤ becomes و)\n",
        "    text = re.sub(r'ؤ', 'و', text)\n",
        "\n",
        "    # 4. Normalize yeh variants (ى and ئ become ي)\n",
        "    text = re.sub(r'[ىئ]', 'ي', text)\n",
        "\n",
        "    # 5. Remove punctuation (updated to remove all punctuation explicitly)\n",
        "    # Combine standard English punctuation with common Arabic punctuation\n",
        "    arabic_punctuation = '،؛؟«»٪'\n",
        "    all_punctuation = string.punctuation + arabic_punctuation\n",
